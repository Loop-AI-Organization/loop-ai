# Supabase (from Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Optional: direct Postgres (Dashboard → Settings → Database)
# DATABASE_URL=postgresql://...

# Optional: for server-side JWT verification (Dashboard → Settings → API → JWT Secret)
# SUPABASE_JWT_SECRET=
