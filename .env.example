# ── Supabase ────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_PASSWORD=...


# ── OpenRouter (LLM) ─────────────────────────────────────────────────────────
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_TEMPERATURE=0.7
# Optional – used by OpenRouter for analytics/ranking
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Loop AI

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated extra CORS origins for production (exact frontend origin[s]).
# Example:
# CORS_ORIGIN=https://your-app.vercel.app,https://www.your-app.com
CORS_ORIGIN=
# Frontend base URL used in invite-link redirects
SITE_URL=http://localhost:5173

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
